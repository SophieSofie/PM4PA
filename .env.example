# =============================================================================
# Agentic RAG — environment template
# Copy this file to ".env" and adjust. Never commit ".env" (secrets).
#
# Structure:
#   [1] Environment-specific — set endpoints, keys, and model names for YOUR
#       infrastructure (Ollama host, Azure, Chroma location, Ollama tags).
#   [2] Defaults & tuning — optional; omit any line to use the built-in default
#       from src/config.py. Values here match those defaults for easy editing.
# =============================================================================


# =============================================================================
# [1] Environment-specific (configure for your setup)
# =============================================================================

# --- Runtime mode ---
# true  = chat/embeddings via Ollama / Open WebUI
# false = chat via Azure OpenAI (embeddings still follow EMBEDDING_* below)
OPEN_SOURCE=true

# --- When OPEN_SOURCE=true: Ollama + Open WebUI ---
# Base URL of the Ollama-compatible HTTP API (no trailing /api/chat; app adds it).
OLLAMA_BASE_URL=https://your-ollama-host/ollama
# Base URL of the Open WebUI HTTP API (used for embeddings if USE_LOCAL_EMBEDDINGS=false).
OPEN_WEBUI_BASE_URL=https://your-openwebui-host/api
# Bearer token if your Open WebUI instance requires authentication; leave empty if none.
OPEN_WEBUI_API_KEY=

# --- When OPEN_SOURCE=false: Azure OpenAI ---
# Azure resource endpoint (e.g. https://your-resource.openai.azure.com/)
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/
# API key from Azure portal for that resource
AZURE_OPENAI_API_KEY=
# Deployment name of the chat model (as in Azure Studio)
AZURE_DEPLOYMENT_NAME=gpt-4o-2024-11-20

# --- Vector store (local paths are fine for a fresh clone) ---
# Directory where ChromaDB persists data on disk
CHROMA_DB_PATH=./chroma_db
# Logical collection name inside Chroma (must match how you ingested documents)
CHROMA_COLLECTION_NAME=your-collection-name

# --- Agent model names (Ollama tags on YOUR server; must exist in `ollama list`) ---
AGENTIC_RETRIEVAL_MODEL=mistral-large:123b
AGENTIC_DRAFT_MODEL=mistral-large:123b
AGENTIC_BPMN_MODEL=mistral-large:123b
AGENTIC_REVISION_MODEL=mistral-large:123b
AGENTIC_VALIDATION_MODEL=mistral-large:123b
AGENTIC_JUDGE_MODEL=mistral-large:123b


# =============================================================================
# [2] Defaults & tuning (optional — same values as src/config.py defaults)
# =============================================================================

# --- Embeddings ---
# Hugging Face / SentenceTransformer id for RAG indexing & retrieval (vector store)
EMBEDDING_MODEL=deepset/mxbai-embed-de-large-v1
# true = compute embeddings locally with sentence-transformers; false = call Open WebUI API
USE_LOCAL_EMBEDDINGS=true
# SentenceTransformer id used only for evaluation metrics (semantic name matching for P/R/F1)
EVAL_SEMANTIC_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# --- LLM sampling ---
# Temperature for Ollama/Azure chat calls (0 = deterministic)
AGENTIC_TEMPERATURE=0.0

# --- API & revision ---
# API_TIMEOUT: maximum seconds to wait for a single LLM HTTP request (Ollama or Azure)
API_TIMEOUT=600
# MAX_REVISION_ITERATIONS: how often the Setting-4 BPMN revision loop may run before stopping
MAX_REVISION_ITERATIONS=2

# --- Debugging ---
# DEBUG: if true, more verbose logs and some extra console output from agents
DEBUG=true

# --- Retrieval (shared / hybrid) ---
# RETRIEVAL_N_RESULTS: candidate pool size from the vector store before filtering
RETRIEVAL_N_RESULTS=50
# RETRIEVAL_TOP_K_SETTING_1: final chunk count for retrieval-only graph (Setting 1)
RETRIEVAL_TOP_K_SETTING_1=20
# RETRIEVAL_TOP_K: final chunk count after hybrid re-ranking (Settings 2–5)
RETRIEVAL_TOP_K=30
# RETRIEVAL_SCORE_THRESHOLD: minimum similarity score (0–1) to keep a retrieved chunk
RETRIEVAL_SCORE_THRESHOLD=0.3
# BM25_TOP_N: how many BM25 hits to merge with vector hits in hybrid retrieval
BM25_TOP_N=100
# BM25_WEIGHT / VECTOR_WEIGHT: blend weights for hybrid score (should sum to 1.0 in typical setups)
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# --- Relevance judge (post-retrieval filter) ---
# RELEVANCE_TOP_N: max chunks passed on after the relevance judge
RELEVANCE_TOP_N=20
# RELEVANCE_MIN_HIGH_MEDIUM: minimum count of high+medium relevance labels before accepting the set
RELEVANCE_MIN_HIGH_MEDIUM=4
# RELEVANCE_RETRY_WITH_NEW_SYNONYMS: if too few good chunks, optionally re-query with new synonyms
RELEVANCE_RETRY_WITH_NEW_SYNONYMS=true
# RELEVANCE_MAX_RETRIES: extra retrieval attempts after failed relevance (0 = no retry)
RELEVANCE_MAX_RETRIES=1

# --- BPMN layout service (local Docker) ---
# BPMN_SERVICE_VERIFY_SSL: verify TLS when calling the BPMN service over HTTPS
BPMN_SERVICE_VERIFY_SSL=true
# BPMN_SERVICE_URL: base URL of the BPMN/XML service used for diagram generation
BPMN_SERVICE_URL=https://bpmnchatbot.aau.at/bpmn-generator 

# --- Ingestion / chunking (character-based) ---
# CHUNK_SIZE: target length of one text chunk
CHUNK_SIZE=800
# CHUNK_OVERLAP: characters overlapping between adjacent chunks
CHUNK_OVERLAP=150
# MIN_CHUNK_SIZE: below this, chunks may be merged
MIN_CHUNK_SIZE=500
# MAX_CHUNK_SIZE: above this, chunks may be split
MAX_CHUNK_SIZE=1000
